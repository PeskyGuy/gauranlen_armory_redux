<?xml version="1.0" encoding="utf-8" ?>
<Defs>

<!-- Tonic Base -->

<ThingDef Name="DryadTonicBase" ParentName="ResourceBase" Abstract="True">
		<thingClass>ThingWithComps</thingClass>
		<stackLimit>10</stackLimit>
		<socialPropernessMatters>false</socialPropernessMatters>
		<orderedTakeGroup>Drug</orderedTakeGroup>
		<statBases>
			<MaxHitPoints>50</MaxHitPoints>
			<MarketValue>120</MarketValue>
			<Mass>0.2</Mass>
			<Flammability>0.7</Flammability>
		</statBases>
		<thingCategories>
			<li>Drugs</li>
		</thingCategories>
		<thingSetMakerTags>
			<li>RewardStandardLowFreq</li>
		</thingSetMakerTags>
		<tradeTags>
			<li>Serum</li>
		</tradeTags>
		<ingestible>
			<preferability>NeverForNutrition</preferability>
			<maxNumToIngestAtOnce>1</maxNumToIngestAtOnce>
			<defaultNumToIngestAtOnce>1</defaultNumToIngestAtOnce>
			<drugCategory>Medical</drugCategory>
			<foodType>Processed</foodType>
			<baseIngestTicks>100</baseIngestTicks>
			<humanlikeOnly>true</humanlikeOnly>
			<chairSearchRadius>0</chairSearchRadius>
			<ingestSound>Ingest_Drink</ingestSound>
			<ingestHoldUsesTable>false</ingestHoldUsesTable>
			<ingestCommandString>Drink {0}</ingestCommandString>
			<ingestReportString>Drinking {0}.</ingestReportString>
			<showIngestFloatOption>false</showIngestFloatOption>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_UseThing"/>
			</outcomeDoers>
		</ingestible>
		<comps>
			<li Class="CompProperties_Drug">
				<listOrder>1200</listOrder>
				<teetotalerCanConsume>true</teetotalerCanConsume>
			</li>
			<li Class="CompProperties_Usable">
				<useLabel>Use {0_label}</useLabel>
				<useJob>Ingest</useJob>
				<showUseGizmo>true</showUseGizmo>
			</li>
			<li Class="CompProperties_Serum"/>
		</comps>
		<recipeMaker>
			<productCount>1</productCount>
			<workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<recipeUsers>
				<li>GroveCrucible</li>
			</recipeUsers>
		</recipeMaker>
	</ThingDef>

<!-- Carrier Dryad -->

<ThingDef ParentName="DryadTonicBase">
		<defName>Tonic_Vigor</defName>
		<label>vigor tonic</label>
		<description>A thick, orange brew made from the heavy muscles of a carrier dryad. Soaked in psychoid, it channels the dryad's unyielding endurance into the drinker, granting the strength to haul great loads. It tastes of bitterness and deep roots.</description>
		<graphicData>
			<texPath>Things/Item/Drug/VigorTonic</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<MarketValue>60</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_UseEffectAddHediff">
				<hediffDef>Buff_Vigor</hediffDef>
				<allowRepeatedUse>true</allowRepeatedUse>
			</li>
			<li Class="Pesky.CompProperties_UseEffectAddHediffWithSeverity">
				<hediffDef>ToxicBuildup</hediffDef>
				<severity>0.1</severity>
				<scaleSeverityByToxResistance>true</scaleSeverityByToxResistance>
			</li>
		</comps>
		<costList>
			<PsychoidLeaves>15</PsychoidLeaves>
			<ComponentDryad_Carrier>2</ComponentDryad_Carrier>
		</costList>
		<recipeMaker>
			<workAmount>800</workAmount>
			<researchPrerequisite>DryadicAlchemy</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

<!-- Clawer Dryad -->

<ThingDef ParentName="DryadTonicBase">
		<defName>Tonic_Feral</defName>
		<label>feral tonic</label>
		<description>A blood-red draught pressed from the heart of a clawer dryad. It stirs a beast-like fury in the blood, sharpening reflexes and driving the drinker to violence. Warriors feel the forest's hunger regarding defense.</description>
		<graphicData>
			<texPath>Things/Item/Drug/FeralTonic</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<MarketValue>80</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_UseEffectAddHediff">
				<hediffDef>Buff_Feral</hediffDef>
				<allowRepeatedUse>true</allowRepeatedUse>
			</li>
			<li Class="Pesky.CompProperties_UseEffectAddHediffWithSeverity">
				<hediffDef>ToxicBuildup</hediffDef>
				<severity>0.4</severity>
				<scaleSeverityByToxResistance>true</scaleSeverityByToxResistance>
			</li>
		</comps>
		<costList>
			<PsychoidLeaves>25</PsychoidLeaves>
			<ComponentDryad_Clawer>2</ComponentDryad_Clawer>
		</costList>
		<recipeMaker>
			<workAmount>800</workAmount>
			<researchPrerequisite>DryadicAlchemy</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

<!-- Barkskin Dryad -->

<ThingDef ParentName="DryadTonicBase">
		<defName>Tonic_Bark</defName>
		<label>bark tonic</label>
		<description>A gritty, brown infusion steeped with shards of barkskin dryad shell. It hardens the drinker's flesh into a wooden callous, turning aside blades and blows. The body becomes stiff and sturdy like an old oak, slowing movement but granting immense resilience.</description>
		<graphicData>
			<texPath>Things/Item/Drug/BarkTonic</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<MarketValue>70</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_UseEffectAddHediff">
				<hediffDef>Buff_Bark</hediffDef>
				<allowRepeatedUse>true</allowRepeatedUse>
			</li>
			<li Class="Pesky.CompProperties_UseEffectAddHediffWithSeverity">
				<hediffDef>ToxicBuildup</hediffDef>
				<severity>0.3</severity>
				<scaleSeverityByToxResistance>true</scaleSeverityByToxResistance>
			</li>
		</comps>
		<costList>
			<WoodLog>30</WoodLog>
			<ComponentDryad_Barkskin>2</ComponentDryad_Barkskin>
		</costList>
		<recipeMaker>
			<workAmount>800</workAmount>
			<researchPrerequisite>DryadicAlchemy</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

<!-- Medicinemaker Dryad -->

<ThingDef ParentName="DryadTonicBase">
		<defName>Tonic_Vital</defName>
		<label>vital tonic</label>
		<description>A glowing, green tonic distilled from the potent regenerative spores of a medicinemaker dryad. Infused with herbal medicines, it accelerates the body's natural defense systems and mends flesh at an incredible rate. It tastes of fresh mint and life.</description>
		<graphicData>
			<texPath>Things/Item/Drug/VitalTonic</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<MarketValue>150</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_UseEffectAddHediff">
				<hediffDef>Buff_Vital</hediffDef>
				<allowRepeatedUse>true</allowRepeatedUse>
			</li>
			<li Class="Pesky.CompProperties_UseEffectAddHediffWithSeverity">
				<hediffDef>ToxicBuildup</hediffDef>
				<severity>0.15</severity>
				<scaleSeverityByToxResistance>true</scaleSeverityByToxResistance>
			</li>
		</comps>
		<costList>
			<MedicineHerbal>5</MedicineHerbal>
			<ComponentDryad_Medicinemaker>2</ComponentDryad_Medicinemaker>
		</costList>
		<recipeMaker>
			<workAmount>1000</workAmount>
			<researchPrerequisite>DryadicAlchemy</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

<!-- Woodmaker Dryad -->

<ThingDef ParentName="DryadTonicBase">
		<defName>Tonic_Sap</defName>
		<label>sap tonic</label>
		<description>A syrupy, amber liquid drawn from the concentrated heartwood of a woodmaker dryad. It sharpens focus and steadies the hands, allowing for tireless labor and efficient craftsmanship. It has a sweet, woody smell like pine resin.</description>
		<graphicData>
			<texPath>Things/Item/Drug/SapTonic</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<MarketValue>100</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_UseEffectAddHediff">
				<hediffDef>Buff_Sap</hediffDef>
				<allowRepeatedUse>true</allowRepeatedUse>
			</li>
			<li Class="Pesky.CompProperties_UseEffectAddHediffWithSeverity">
				<hediffDef>ToxicBuildup</hediffDef>
				<severity>0.2</severity>
				<scaleSeverityByToxResistance>true</scaleSeverityByToxResistance>
			</li>
		</comps>
		<costList>
			<PsychoidLeaves>20</PsychoidLeaves>
			<ComponentDryad_Woodmaker>2</ComponentDryad_Woodmaker>
		</costList>
		<recipeMaker>
			<workAmount>800</workAmount>
			<researchPrerequisite>DryadicAlchemy</researchPrerequisite>
		</recipeMaker>
	</ThingDef>

<!-- Gaumaker Dryad -->

<ThingDef ParentName="DryadTonicBase">
		<defName>Tonic_Sage</defName>
		<label>sage tonic</label>
		<description>A shimmering, golden elixir containing the pure connection of a gaumaker dryad. It expands the mind and deepens awareness, connecting the drinker's thoughts to the collective wisdom of the grove. It is said to taste like starlight and ancient memories.</description>
		<graphicData>
			<texPath>Things/Item/Drug/SageTonic</texPath>
