<Defs>

<!-- Immature Dryad -->

<ThingDef ParentName="BaseWeaponNeolithic">
    <defName>Bow_Sinew</defName>
    <label>sinew bow</label>
    <description>A shortbow made from the bone and sinew of an immature dryad.</description>
    <possessionCount>1</possessionCount>
    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/BowSinew</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Bow_Small</soundInteract>
    <costList>
      <WoodLog>30</WoodLog>
      <ComponentDryad_Basic>2</ComponentDryad_Basic>
    </costList>
    <statBases>
      <WorkToMake>2400</WorkToMake>
      <Mass>0.8</Mass>
      <AccuracyTouch>0.85</AccuracyTouch>
      <AccuracyShort>0.70</AccuracyShort>
      <AccuracyMedium>0.55</AccuracyMedium>
      <AccuracyLong>0.35</AccuracyLong>
      <RangedWeapon_Cooldown>1.25</RangedWeapon_Cooldown>
    </statBases>
    <weaponTags>
      <li>NeolithicRangedBasic</li>
    </weaponTags>
    <weaponClasses>
      <li>Ranged</li>
      <li>RangedLight</li>
    </weaponClasses>
    <recipeMaker>
      <recipeUsers>
          <li>GroveCrucible</li>
      </recipeUsers>
      <skillRequirements>
        <Crafting>2</Crafting>
        <Plants>4</Plants>
      </skillRequirements>
      <displayPriority>550</displayPriority>
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Arrow_Sinew</defaultProjectile>
        <warmupTime>0.85</warmupTime>
        <range>19</range>
        <soundCast>Bow_Small</soundCast>
      </li>
    </verbs>
    <tools>
      <li>
        <label>limb</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>4</power>
        <cooldownTime>1</cooldownTime>
      </li>
    </tools>
    <rotateInShelves>false</rotateInShelves>
  </ThingDef>
  <ThingDef ParentName="BaseProjectileNeolithic">
    <defName>Arrow_Sinew</defName>
    <label>sinew arrow</label>
    <graphicData>
      <texPath>Things/Projectile/Arrow_Small</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>Arrow</damageDef>
      <damageAmountBase>7</damageAmountBase>
      <speed>50</speed>
    </projectile>
  </ThingDef>

