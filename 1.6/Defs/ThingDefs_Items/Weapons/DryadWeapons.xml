<ThingDef ParentName="GA_BaseShield">
        <defName>BarkskinShield</defName>
        <label>barkskin shield</label>
        <description>A shield with the mangled face of a barkskin dryad, provides decent protection against everything but heat.</description>
        <graphicData>
            <texPath>Things/Item/Equipment/Shield/BarkskinShield</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>1</drawSize>
        </graphicData>
        <costList>
            <WoodLog>60</WoodLog>
            <Steel>20</Steel>
	      		<ComponentDryad_Barkskin>2</ComponentDryad_Barkskin>
        </costList>
    <recipeMaker>
			<researchPrerequisite>DryadicArmaments</researchPrerequisite>
			<recipeUsers>
				<li>GroveCrucible</li>
			</recipeUsers>
			<skillRequirements>
				<Crafting>5</Crafting>
				<Plants>5</Plants>
			</skillRequirements>
			<displayPriority>510</displayPriority>
		</recipeMaker>
        <statBases>
            <MaxHitPoints>150</MaxHitPoints>
            <Flammability>1.5</Flammability>
            <ArmorRating_Sharp>0.65</ArmorRating_Sharp>
            <ArmorRating_Blunt>0.6</ArmorRating_Blunt>
            <ArmorRating_Heat>0.15</ArmorRating_Heat>
            <WorkToMake>3600</WorkToMake>
            <Mass>2.7</Mass>
        </statBases>
        <equippedStatOffsets>
            <MoveSpeed>-0.1</MoveSpeed>
        </equippedStatOffsets>
        <comps>
            <li Class="VEF.Apparels.CompProperties_Shield">
                <useDeflectMetalEffect>false</useDeflectMetalEffect>
                <coveredBodyPartGroups>
                    <li>Neck</li>
                    <li>Torso</li>
                    <li>Arms</li>
				          	<li>Legs</li>
                    <li>Hands</li>
                </coveredBodyPartGroups>
                <offHandGraphicData>
                    <texPath>Things/Item/Equipment/Shield/BarkskinShield</texPath>
                    <graphicClass>Graphic_Multi</graphicClass>
                    <drawSize>1.2</drawSize>
                </offHandGraphicData>
                <offHandHoldOffset>
                    <northDefault>
                        <offset>(-0.05, 0, 0.2)</offset>
                        <behind>true</behind>
                    </northDefault>
                    <east>
                        <offset>(-0.15, 0, 0.2)</offset>
                        <behind>true</behind>
                    </east>
                    <south>
                        <offset>(0.2, -0.04, 0.2)</offset>
                    </south>
                    <west>
                        <offset>(0.15, 0, 0.2)</offset>
                    </west>
                </offHandHoldOffset>
            </li>
        </comps>
    </ThingDef>

